APP_NAME="Shay Ghazalah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8000

# Arabic / RTL by default
APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Use MySQL in production. SQLite is fine for quick local testing.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shay_ghazalah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@shayghazalah.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Moyasar Payment Gateway (https://dashboard.moyasar.com -> Settings -> API keys)
# These can also be managed at runtime from the Admin Dashboard (Settings page),
# which take precedence over these .env values when present.
# ---------------------------------------------------------------------------
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
# Shared secret you set when creating the webhook in the Moyasar dashboard.
MOYASAR_WEBHOOK_SECRET=
